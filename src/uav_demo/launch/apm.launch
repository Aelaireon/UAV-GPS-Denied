<launch>
	<!-- vim: set ft=xml noet : -->
	<!-- example launch script for ArduPilot based FCU's -->

	<arg name="fcu_url" default="/dev/ttyACM0:921600" />
	<!-- udev rules for cubeorange -->
	<!-- <arg name="fcu_url" default="/dev/ttyFCU:115200" /> -->
	<arg name="gcs_url" default="" />
	<arg name="tgt_system" default="1" />
	<arg name="tgt_component" default="1" />
	<arg name="log_output" default="screen" />
	<arg name="fcu_protocol" default="v2.0" />
	<arg name="respawn_mavros" default="false" />
	<arg name="namespace" default="uav/mavros"/>
	<include file="$(find-pkg-share uav_demo)/launch/node.launch">
		<!-- <arg name="pluginlists_yaml" value="$(find-pkg-share uav_demo)/config/mavros/apm.pluginlists.yaml" /> -->
		<arg name="pluginlists_yaml" value="$(find-pkg-share uav_demo)/config/mavros/nuclear.apm.pluginlists.yaml" />
		<arg name="config_yaml" value="$(find-pkg-share uav_demo)/config/mavros/apm.config.yaml" />
		<arg name="fcu_url" value="$(var fcu_url)" />
		<arg name="gcs_url" value="$(var gcs_url)" />
		<arg name="tgt_system" value="$(var tgt_system)" />
		<arg name="tgt_component" value="$(var tgt_component)" />
		<arg name="fcu_protocol" value="$(var fcu_protocol)" />
		<arg name="respawn_mavros" value="$(var respawn_mavros)" />
		<arg name="namespace" value="$(var namespace)"/>
	</include>
</launch>
